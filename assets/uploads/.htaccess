# Uploads — bu papkadan PHP/script bajarilmasligi shart
# (bu OS darajasidagi himoya, PHP'da qilib bo'lmaydi)

<FilesMatch "\.(php|phtml|phar|cgi|pl|py|sh|exe|asp|aspx|jsp|svg|html?)$">
    Require all denied
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

RemoveHandler .php .phtml .phar .cgi .pl

Options -Indexes -ExecCGI
