# =================================================
# VatanParvar Yaypan — environment configuration
# =================================================
# Production'da bu fayldan nusxa olib `.env` nomi bilan saqlang.
# .env Git'ga commit qilinmasligi kerak (.gitignore ichida).
# =================================================

# Application
APP_ENV=production
APP_DEBUG=0
# 32+ belgili tasodifiy string. Saytdagi signed token'lar uchun.
# Yangi yaratish: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Database
DB_HOST=localhost
DB_NAME=vatanparvar_yaypan
DB_USER=root
DB_PASS=

# Telegram bot
TELEGRAM_BOT_USERNAME=vatanparvar_bot
# BotFather'dan setWebhook qilganda secret_token sifatida yuboring.
# Faqat shu tokenli so'rovlar qabul qilinadi.
TELEGRAM_WEBHOOK_SECRET=

# Cron
CRON_SECRET=

# CORS — qo'shimcha allowed origins (vergul bilan)
CORS_ALLOWED_ORIGINS=

# Trusted proxies (Cloudflare/load-balancer ortida bo'lganda)
# X-Forwarded-For header'iga ishonish uchun manzilni shu yerga yozing
TRUSTED_PROXIES=
